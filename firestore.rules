rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Business Profile ---
    function isValidBusinessProfile(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             (data.get('address', '') is string && data.get('address', '').size() <= 500) &&
             (data.get('taxId', '') is string && data.get('taxId', '').size() <= 100) &&
             (data.get('logoUrl', '') is string && data.get('logoUrl', '').size() <= 2000000) &&
             (data.get('logoPosition', 'top_left') in ['top_left', 'top_center', 'top_right', 'bottom_left', 'bottom_center', 'bottom_right']) &&
             (data.get('currency', 'USD') is string && data.get('currency', 'USD').size() <= 10) &&
             (data.get('defaultAdjustments', []) is list && data.get('defaultAdjustments', []).size() <= 20) &&
             (data.get('updatedAt', request.time) is timestamp);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidBusinessProfile(incoming()) && 
                    incoming().keys().hasAll(['name', 'email']) && incoming().keys().size() <= 13;
      allow update: if isOwner(userId) && isValidId(userId) && isValidBusinessProfile(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'address', 'taxId', 'logoUrl', 'logoPosition', 'currency', 'defaultAdjustments', 'updatedAt', 'createdAt', 'id', 'uid', 'userId'])
      );
    }

    // --- Clients ---
    function isValidClient(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             (data.get('address', '') is string && data.get('address', '').size() <= 500) &&
             (data.get('phone', '') is string && data.get('phone', '').size() <= 50) &&
             (data.get('id', '') is string);
    }

    match /users/{userId}/clients/{clientId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(clientId) && isValidClient(incoming()) &&
                    incoming().keys().hasAll(['name', 'email']) && incoming().keys().size() <= 12;
      allow update: if isOwner(userId) && isValidClient(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'address', 'taxId', 'phone', 'id'])
      );
      allow delete: if isOwner(userId);
    }

    // --- Products ---
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.unitPrice is number && data.unitPrice >= 0 &&
             (data.get('costPrice', 0) is number && data.get('costPrice', 0) >= 0) &&
             (data.get('description', '') is string && data.get('description', '').size() <= 1000) &&
             (data.get('imageUrl', '') is string && data.get('imageUrl', '').size() <= 2000000) &&
             (data.get('id', '') is string);
    }

    match /users/{userId}/products/{productId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(productId) && isValidProduct(incoming()) &&
                    incoming().keys().hasAll(['name', 'unitPrice']) && incoming().keys().size() <= 10;
      allow update: if isOwner(userId) && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'unitPrice', 'costPrice', 'description', 'imageUrl', 'id'])
      );
      allow delete: if isOwner(userId);
    }

    // --- Invoices ---
    function isValidInvoice(data) {
      return data.number is string && data.number.size() > 0 && data.number.size() <= 50 &&
             data.date is string && data.date.size() > 0 &&
             data.clientId is string && isValidId(data.clientId) &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 100 &&
             data.total is number && data.total >= 0 &&
             data.status in ['draft', 'sent', 'paid', 'overdue'] &&
             (data.get('adjustments', []) is list && data.get('adjustments', []).size() <= 20) &&
             (data.get('updatedAt', request.time) is timestamp) &&
             (data.get('createdAt', request.time) is timestamp);
    }

    match /users/{userId}/invoices/{invoiceId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(invoiceId) && isValidInvoice(incoming()) &&
                    exists(/databases/$(database)/documents/users/$(userId)/clients/$(incoming().clientId));
      allow update: if isOwner(userId) && isValidInvoice(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['number', 'date', 'dueDate', 'status', 'clientId', 'items', 'taxRate', 'taxAmount', 'adjustments', 'subtotal', 'total', 'notes', 'updatedAt', 'createdAt', 'id'])
      );
      allow delete: if isOwner(userId);
    }
  }
}
